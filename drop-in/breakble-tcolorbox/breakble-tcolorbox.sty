%% Unofficial local entry point for the patched tcolorbox copy.
%%
%% Load this package instead of loading tcolorbox directly.  It passes all
%% package options through to the patched tcolorbox files found next to this
%% wrapper or via TEXINPUTS.
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{breakble-tcolorbox/breakble-tcolorbox}[2026/06/01 local nested-breakable tcolorbox wrapper]

\DeclareOption*{\PassOptionsToPackage{\CurrentOption}{tcolorbox}}
\ProcessOptions\relax

\makeatletter
\@ifpackageloaded{tcolorbox}{%
  \PackageError{breakble-tcolorbox}{tcolorbox is already loaded}{%
    Load breakble-tcolorbox before any direct tcolorbox load.%
  }%
}{}
\@ifundefined{@currpath}{\def\@currpath{}}{}%
\@ifundefined{input@path}{\def\input@path{}}{}%
\edef\breakbletcb@path{\@currpath}%
\ifx\breakbletcb@path\@empty\else
  \edef\input@path{{\breakbletcb@path}\input@path}%
  \edef\tcbpkgprefix{\breakbletcb@path}%
\fi
\ifx\breakbletcb@path\@empty
  \RequirePackage{tcolorbox}%
\else
  \RequirePackage{\breakbletcb@path tcolorbox}%
\fi
\makeatother
\endinput

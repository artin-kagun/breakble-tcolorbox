%% Unofficial local entry point for the patched tcolorbox copy.
%%
%% Load this package instead of loading tcolorbox directly.  It passes all
%% package options through to the patched tcolorbox files found via TEXINPUTS.
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{breakble-tcolorbox}[2026/06/01 local nested-breakable tcolorbox wrapper]

\DeclareOption*{\PassOptionsToPackage{\CurrentOption}{tcolorbox}}
\ProcessOptions\relax

\makeatletter
\@ifpackageloaded{tcolorbox}{%
  \PackageError{breakble-tcolorbox}{tcolorbox is already loaded}{%
    Load breakble-tcolorbox before any direct tcolorbox load.%
  }%
}{}
\makeatother

\RequirePackage{tcolorbox}
\endinput
